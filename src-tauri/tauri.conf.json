{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FinanzApp",
  "version": "1.0.14",
  "identifier": "com.finanzapp.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FinanzApp",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https: ipc: http://ipc.localhost; img-src 'self' data: https:; font-src 'self' data:; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "Copyright (c) 2026 FinanzApp",
    "category": "Finance",
    "shortDescription": "Gestion de finanzas personales",
    "longDescription": "FinanzApp - Aplicacion completa de finanzas personales",
    "windows": {
      "wix": {
        "language": "es-ES"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": [
          "Spanish"
        ]
      }
    }
  }
}