<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header: nombre + saldo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FinanzApp"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:alpha="0.85" />

        <TextView
            android:id="@+id/widget_last_sync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin sincronizar"
            android:textColor="#ffffff"
            android:textSize="9sp"
            android:alpha="0.6" />
    </LinearLayout>

    <!-- Saldo total -->
    <TextView
        android:id="@+id/widget_balance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="10dp"
        android:text="RD$0.00"
        android:textColor="#ffffff"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Botones rapidos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="4">

        <!-- Ingreso -->
        <LinearLayout
            android:id="@+id/btn_ingreso"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_button_ingreso"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingreso"
                android:textColor="#ffffff"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Gasto -->
        <LinearLayout
            android:id="@+id/btn_gasto"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_button_gasto"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gasto"
                android:textColor="#ffffff"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Transferencia -->
        <LinearLayout
            android:id="@+id/btn_transferencia"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_button_transferencia"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↔"
                android:textColor="#ffffff"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transf."
                android:textColor="#ffffff"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Abrir app -->
        <LinearLayout
            android:id="@+id/btn_open"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_button_open"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="#ffffff"
                android:textSize="20sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abrir"
                android:textColor="#ffffff"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
